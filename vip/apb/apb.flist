// =============================================================================
// apb.flist - APB VIP 文件列表
//
// 说明：
//   供 VCS 编译时通过 -f 参数加载。
//   接口文件（apb_if.sv）须在 package 之前单独编译。
//   其余文件通过 apb_pkg.sv 的 `include 链式引入，无需单独列出。
// =============================================================================

+incdir+${REPO_ROOT}/vip/apb

// 接口（需在 package 外独立声明）
${REPO_ROOT}/vip/apb/apb_if.sv

// VIP 顶层包（内部 `include 全部 VIP 类）
${REPO_ROOT}/vip/apb/apb_pkg.sv
